{
  "expo": {
    "name": "AgroTech",
    "slug": "AgroTech",
    "version": "1.0.0",

    "web": {
      "favicon": "src/assets/images/agrotechlogo.jpeg"
    },

    "experiments": {
      "tsconfigPaths": true
    },

    "plugins": [],

    "orientation": "portrait",
    "icon": "src/assets/images/agrotechlogo.jpeg",

    "userInterfaceStyle": "light",

    "splash": {
      "image": "src/assets/images/agrotechlogo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "src/assets/images/agrotechlogo.jpeg",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "adjustResize"
    }
  }
}
